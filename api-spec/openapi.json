{
  "openapi": "3.0.3",
  "info": {
    "title": "Deployments Data Service API",
    "version": "0.0.1-SNAPSHOT",
    "description": "API for deployments data service"
  },
  "paths": {
    "/health": {
      "get": {
        "summary": "Health check endpoint",
        "operationId": "getHealth",
        "responses": {
          "200": {
            "description": "Service is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "UP"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/deployments": {
      "get": {
        "summary": "List deployments with pagination and filtering",
        "operationId": "listDeployments",
        "parameters": [
          {
            "name": "service",
            "in": "query",
            "required": false,
            "description": "Filter by microservice name",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "status",
            "in": "query",
            "required": false,
            "description": "Filter by deployment status",
            "schema": {
              "type": "string",
              "enum": ["success", "failed", "rolled_back", "in_progress", "cancelled"]
            }
          },
          {
            "name": "environment",
            "in": "query",
            "required": false,
            "description": "Filter by environment",
            "schema": {
              "type": "string",
              "enum": ["production", "staging", "canary"]
            }
          },
          {
            "$ref": "#/components/parameters/pageParam"
          },
          {
            "$ref": "#/components/parameters/pageSizeParam"
          }
        ],
        "responses": {
          "200": {
            "$ref": "./responses/success/deployments-list.json"
          },
          "400": {
            "$ref": "./responses/failure/error-bad-request.json"
          }
        }
      }
    },
    "/deployments/{id}": {
      "get": {
        "summary": "Get details of a single deployment event",
        "operationId": "getDeployment",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Unique identifier of the deployment event",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "$ref": "./responses/success/deployment-detail.json"
          },
          "404": {
            "$ref": "./responses/failure/error-not-found.json"
          }
        }
      }
    },
    "/metrics": {
      "get": {
        "summary": "Fetch metrics data for services",
        "operationId": "getMetrics",
        "parameters": [
          {
            "name": "environment",
            "in": "query",
            "required": false,
            "description": "Filter by environment(s)",
            "explode": true,
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "production",
                  "staging",
                  "canary"
                ]
              }
            }
          },
          {
            "name": "service",
            "in": "query",
            "required": false,
            "description": "Filter by microservice name",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "timeRange",
            "in": "query",
            "required": false,
            "description": "Filter by time range (e.g. 1h, 1d, 1m). Min: 1h, Max: 12m",
            "schema": {
              "type": "string",
              "default": "1d",
              "pattern": "^([1-9][0-9]*)([hdm])$"
            }
          },
          {
            "$ref": "#/components/parameters/pageParam"
          },
          {
            "$ref": "#/components/parameters/pageSizeParam"
          }
        ],
        "responses": {
          "200": {
            "$ref": "./responses/success/service-metrics-list.json"
          },
          "400": {
            "$ref": "./responses/failure/error-bad-request.json"
          }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "pageParam": {
        "name": "page",
        "in": "query",
        "required": false,
        "description": "Page number (0-indexed)",
        "schema": {
          "type": "integer",
          "default": 0
        }
      },
      "pageSizeParam": {
        "name": "page_size",
        "in": "query",
        "required": false,
        "description": "Size of the page",
        "schema": {
          "type": "integer",
          "default": 10
        }
      }
    }
  }
}